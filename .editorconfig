root = true

[*]
indent_style = space
indent_size = 2
tab_width = 2
continuation_indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{kt,kts}]
indent_size = 2
tab_width = 2
continuation_indent_size = 2
ij_continuation_indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
